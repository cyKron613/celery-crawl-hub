# Celery Crawl Hub 环境变量示例
# 使用方式：复制为 .env 后按需修改；请勿提交真实 .env。

# -----------------------------
# Runtime
# -----------------------------
ENVIRONMENT=DEV
BACKEND_SERVER_HOST=0.0.0.0
BACKEND_SERVER_PORT=8000
BACKEND_SERVER_WORKERS=1
API_PREFIX=/api
DOCS_URL=/api-doc.html
OPENAPI_URL=/api.json
REDOC_URL=/api-redoc.html
ALLOWED_ORIGINS=http://127.0.0.1:8111,http://localhost:7860

# Swagger / ReDoc 登录保护
DOCS_AUTH_USERNAME=admin
DOCS_AUTH_PASSWORD=change-me

# -----------------------------
# Celery / Redis broker
# -----------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_BROKER_POOL_LIMIT=30
CELERY_BROKER_CONNECTION_TIMEOUT=5
CELERY_TIMEZONE=Asia/Shanghai
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900
CELERY_TASK_ALWAYS_EAGER=false
# Worker 并发配置（prefork 进程数）
CRAWLER_WORKER_CONCURRENCY=4
TRANSLATE_WORKER_CONCURRENCY=2
CRAWLER_SCHEDULER_SCAN_SECONDS=60
TRANSLATE_SCHEDULER_SCAN_SECONDS=60
CRAWLER_EXECUTION_PREVIEW_LIMIT=10

# -----------------------------
# Database
# DATABASE_TYPE 可选：postgresql / oceanbase（按代码适配情况配置）
# POSTGRES_CONNECT 示例：postgresql+asyncpg、postgresql+psycopg2、mysql+pymysql
# -----------------------------
DATABASE_TYPE=postgresql
POSTGRES_CONNECT=postgresql+asyncpg
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crawler_studio
POSTGRES_USERNAME=crawler
POSTGRES_PASSWORD=change-me
POSTGRES_SCHEMA=sdc_test

# 可选：第二数据库连接，生产/同步场景使用；本地可与主库一致。
POSTGRES_CONNECT_ANOTHER=postgresql+asyncpg
POSTGRES_HOST_ANOTHER=localhost
POSTGRES_PORT_ANOTHER=5432
POSTGRES_DB_ANOTHER=crawler_studio
POSTGRES_USERNAME_ANOTHER=crawler
POSTGRES_PASSWORD_ANOTHER=change-me
POSTGRES_SCHEMA_ANOTHER=sdc_test

DB_MAX_POOL_CON=10
DB_POOL_SIZE=5
DB_POOL_OVERFLOW=10
DB_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
DB_POOL_RESET_ON_RETURN=rollback
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=0.5
DB_RETRY_BACKOFF=2
IS_DB_ECHO_LOG=false
IS_DB_FORCE_ROLLBACK=false
IS_DB_EXPIRE_ON_COMMIT=false

# -----------------------------
# Redis cache/client
# -----------------------------
PROD_REDIS_HOST=localhost
PROD_REDIS_PORT=6379
PROD_REDIS_PASSWORD=
PROD_REDIS_DB=0
PROD_REDIS_CLUSTER=false
PROD_REDIS_NODES=

TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_PASSWORD=
TEST_REDIS_DB=0
TEST_REDIS_CLUSTER=false

# -----------------------------
# Crawler / persistence options
# -----------------------------
CRAWLER_LOG_TABLE_NAME=ex_crawl_log
CRAWLER_LOG_DETAIL_TABLE_NAME=ex_crawl_log_detail
# CRAWL_TABLE_NAME 是翻译任务读取/更新的业务表（需包含 schema）
CRAWL_TABLE_NAME=sdc_test.ex_shipping_information
INSERT_INTO_PROD=false
INSERT_INTO_SDC=false

# -----------------------------
# Optional integrations
# -----------------------------
OPENAI_API_KEY=
OBS_ACCESS_KEY=
OBS_SECRET_KEY=
OBS_SERVER_URL=
OBS_BUCKET_NAME=

# Gradio console
GRADIO_API_BASE_URL=http://127.0.0.1:8000/api
GRADIO_SERVER_HOST=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_APP_TITLE=Crawler Studio Console

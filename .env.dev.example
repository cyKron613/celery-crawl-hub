# Celery Crawl Hub — 本地开发环境变量
# 使用方式：复制为 .env.dev 后按需修改；请勿提交真实 .env.dev。
# 本模板面向 Docker Compose 本地开发场景，数据库/Redis 由 Compose 自动提供。

# -----------------------------
# Runtime
# -----------------------------
ENVIRONMENT=DEV
BACKEND_SERVER_HOST=0.0.0.0
BACKEND_SERVER_PORT=8000
BACKEND_SERVER_WORKERS=1
API_PREFIX=/api
DOCS_URL=/api-doc.html
OPENAPI_URL=/api.json
REDOC_URL=/api-redoc.html
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Swagger / ReDoc 登录保护
DOCS_AUTH_USERNAME=admin
DOCS_AUTH_PASSWORD=dev-only

# -----------------------------
# Celery / Redis broker
# -----------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/8
CELERY_BROKER_POOL_LIMIT=30
CELERY_BROKER_CONNECTION_TIMEOUT=5
CELERY_TIMEZONE=Asia/Shanghai
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900
CELERY_TASK_ALWAYS_EAGER=false
CRAWLER_WORKER_CONCURRENCY=2
TRANSLATE_WORKER_CONCURRENCY=1
CRAWLER_SCHEDULER_SCAN_SECONDS=60
TRANSLATE_SCHEDULER_SCAN_SECONDS=60
CRAWLER_EXECUTION_PREVIEW_LIMIT=10

# -----------------------------
# Database
# -----------------------------
DATABASE_TYPE=postgresql
POSTGRES_CONNECT=postgresql+asyncpg
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crawler_studio
POSTGRES_USERNAME=crawler
POSTGRES_PASSWORD=dev-only
POSTGRES_SCHEMA=sdc_test

POSTGRES_CONNECT_ANOTHER=postgresql+asyncpg
POSTGRES_HOST_ANOTHER=localhost
POSTGRES_PORT_ANOTHER=5432
POSTGRES_DB_ANOTHER=crawler_studio
POSTGRES_USERNAME_ANOTHER=crawler
POSTGRES_PASSWORD_ANOTHER=dev-only
POSTGRES_SCHEMA_ANOTHER=sdc_test

DB_POOL_SIZE=5
DB_POOL_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
DB_POOL_RESET_ON_RETURN=rollback
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=0.5
DB_RETRY_BACKOFF=2
IS_DB_ECHO_LOG=false

# -----------------------------
# Redis cache/client
# -----------------------------
PROD_REDIS_HOST=localhost
PROD_REDIS_PORT=6379
PROD_REDIS_PASSWORD=
PROD_REDIS_DB=0
PROD_REDIS_CLUSTER=false
PROD_REDIS_NODES=

TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_PASSWORD=
TEST_REDIS_DB=0
TEST_REDIS_CLUSTER=false

# -----------------------------
# Crawler / persistence options
# -----------------------------
CRAWLER_LOG_TABLE_NAME=ex_crawl_log
CRAWLER_LOG_DETAIL_TABLE_NAME=ex_crawl_log_detail
CRAWL_TABLE_NAME=ex_shipping_information
INSERT_INTO_PROD=false
INSERT_INTO_SDC=false
CRAWL_ENGINE=playwright

# SDC 数据库（仅 INSERT_INTO_SDC=true 时生效）
SDC_TABLE_NAME=ex_shipping_information
SDC_POSTGRES_CONNECT=postgresql+psycopg2
SDC_POSTGRES_HOST=localhost
SDC_POSTGRES_PORT=5432
SDC_POSTGRES_DB=crawler_studio
SDC_POSTGRES_USERNAME=crawler
SDC_POSTGRES_PASSWORD=dev-only
SDC_POSTGRES_SCHEMA=public

# -----------------------------
# OceanBase（DATABASE_TYPE=oceanbase 时生效）
# -----------------------------
OCEANBASE_HOST=localhost
OCEANBASE_PORT=2883
OCEANBASE_DB=web_crawler
OCEANBASE_USERNAME=crawler@tenant#cluster
OCEANBASE_PASSWORD=dev-only

# -----------------------------
# 生产入库数据库（INSERT_INTO_PROD=true 时生效）
# -----------------------------
PROD_DB_HOST=localhost
PROD_DB_PORT=60235
PROD_DB_NAME=web_crawler
PROD_DB_USERNAME=dev-only
PROD_DB_PASSWORD=dev-only

# -----------------------------
# Optional integrations
# -----------------------------
OPENAI_API_KEY=

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

# Docker Compose 端口映射
# WEB_PORT=3000

# 华为 OBS 对象存储（可选）
OBS_ACCESS_KEY=
OBS_SECRET_KEY=
OBS_SERVER_URL=
OBS_BUCKET_NAME=

# 微信公众号爬虫（可选）
WECHAT_TOKEN=
WECHAT_COOKIE=
